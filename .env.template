# VidEngram Environment Configuration
# Copy to .env and fill in your values

# ── Qwen2.5-Omni via vLLM-Omni ──────────────────────
QWEN_BASE_URL=http://localhost:8091/v1
QWEN_MODEL=Qwen/Qwen2.5-Omni-7B
QWEN_API_KEY=EMPTY

# ── EverMemOS ────────────────────────────────────────
EVERMEMOS_BASE_URL=http://localhost:8001

# ── LLM for EverMemOS memory extraction ─────────────
# EverMemOS uses an LLM internally for MemCell/Episode extraction.
# Set this to your preferred LLM provider.
LLM_API_KEY=your-openai-or-openrouter-api-key
LLM_MODEL=gpt-4o-mini
# Or use OpenRouter:
# LLM_API_KEY=your-openrouter-key
# LLM_MODEL=openai/gpt-4o-mini

# ── Optional: External planning LLM for agent ───────
# If not set, falls back to Qwen2.5-Omni
# PLANNING_LLM_BASE_URL=
# PLANNING_LLM_MODEL=
# PLANNING_LLM_API_KEY=

# ── Working directory ────────────────────────────────
VIDENGRAM_WORK_DIR=/tmp/videngram
