# VidEngram Environment Configuration
# Copy to .env and fill in your values

# ── Qwen2.5-Omni via vLLM-Omni ──────────────────────
# QWEN_BASE_URL=
# QWEN_MODEL=qwen2.5-omni-7b
# QWEN_API_KEY=your-qwen-api-key
QWEN_BASE_URL=http://localhost:8091/v1
QWEN_MODEL=Qwen/Qwen2.5-Omni-7B
QWEN_API_KEY=EMPTY

# ── EverMemOS ────────────────────────────────────────
EVERMEMOS_BASE_URL=http://localhost:8001

# ── LLM for EverMemOS memory extraction ─────────────
# EverMemOS uses an LLM internally for MemCell/Episode extraction.
# Set this to your preferred LLM provider.
LLM_API_KEY=EMPTY
LLM_MODEL=Qwen/Qwen2.5-Omni-7B
LLM_BASE_URL=http://localhost:8091/v1
# Or use OpenRouter:
# LLM_API_KEY=your-openrouter-key
# LLM_MODEL=openai/gpt-4o-mini

# ── Optional: External planning LLM for agent ───────
# If not set, falls back to Qwen2.5-Omni
PLANNING_LLM_BASE_URL=
PLANNING_LLM_MODEL=gpt-4o
PLANNING_LLM_API_KEY=your-llm-api-key

# ── Optional (strongly recommended): Speech Transcription (Whisper-compatible API) ────
# If TRANSCRIBER_API_KEY is unset, ASR is skipped entirely: video segmentation
# falls back to silence/scene detection, subtitles are disabled, Qwen self-
# transcribes dialogue (lower accuracy), and no speech memories are stored.
TRANSCRIBER_BASE_URL=
TRANSCRIBER_API_KEY=your-transcriber-api-key
TRANSCRIBER_MODEL=whisper-1

# ── Working directory ────────────────────────────────
# REMOTE_HOST / REMOTE_WORK_DIR: when both are set, uploaded videos are SCP'd to the
# remote server and all ffmpeg/ffprobe operations (segmenter, captioner, transcriber)
# run via SSH on that server. Leave unset to run everything locally (requires local ffmpeg).
# REMOTE_HOST=user@your-remote-host
# REMOTE_WORK_DIR=/home/user/videngram/work
VIDENGRAM_WORK_DIR=/tmp/videngram
